p3 <- ggplot(carrier_df, aes(x = TotalFlights, y = CancelRate, label = CarrierName)) +
geom_point(aes(size = AvgArrDelay), color = "#D35400", alpha = 0.7) +
geom_text(vjust = 1.5, size = 3, check_overlap = TRUE) +
scale_x_log10(labels = label_number(scale_cut = cut_short_scale())) + # Log scale for huge differences
theme_light() +
labs(
title = "Reliability Matrix: Volume vs. Cancellations",
subtitle = "Size of bubble = Average Delay Severity",
x = "Total Flights (Log Scale)",
y = "Cancellation Rate (%)",
size = "Avg Delay"
)
print(p3)
install.packages("scales")
install.packages("ggplot2")
install.packages("tidyverse")
install.packages("scales")
# 1. SETUP & LIBRARIES
# If you don't have these, run: install.packages(c("tidyverse", "ggplot2", "scales"))
library(tidyverse)
# Ensure Date format is correct
daily_df$FlightDate <- as.Date(daily_df$FlightDate)
# ==========================================
# UNIT II: AIRLINE PERFORMANCE ANALYSIS
# ==========================================
# 1. SETUP & LIBRARIES
# If you don't have these, run: install.packages(c("tidyverse", "ggplot2", "scales"))
library(tidyverse)
library(ggplot2)
library(scales)
# 2. HELPER FUNCTION (The "Pro" Move)
# Spark saves files with ugly names like "part-00000-tid...csv".
# This function automatically finds the correct CSV inside the folder so you don't have to rename it.
read_spark_output <- function(folder_name) {
# Look for the .csv file inside the folder
file_path <- list.files(path = paste0("project_outputs/", folder_name),
pattern = "*.csv",
full.names = TRUE)[1]
if (is.na(file_path)) {
stop(paste("Error: Could not find CSV in", folder_name, "- Did you run the Spark job?"))
}
message(paste("Loading:", file_path))
return(read_csv(file_path, show_col_types = FALSE))
}
# 3. LOAD DATA
# We load the specific aggregated datasets we created in Python
daily_df <- read_spark_output("daily_trends")
carrier_df <- read_spark_output("carrier_stats_named")
# Ensure Date format is correct
daily_df$FlightDate <- as.Date(daily_df$FlightDate)
# ==========================================
# VISUALIZATION 1: TIME SERIES ANALYSIS
# Goal: Show how delays fluctuate over time.
# ==========================================
p1 <- ggplot(daily_df, aes(x = FlightDate)) +
# Departure Delay Line (Red)
geom_line(aes(y = AvgDepDelay, color = "Departure Delay"), size = 0.8, alpha = 0.8) +
# Arrival Delay Line (Blue)
geom_line(aes(y = AvgArrDelay, color = "Arrival Delay"), size = 0.8, alpha = 0.8) +
# Styling
scale_color_manual(values = c("Departure Delay" = "#E74C3C", "Arrival Delay" = "#2980B9")) +
theme_minimal() +
labs(
title = "Flight Delay Trends (Time Series)",
subtitle = "Daily Average Departure vs. Arrival Delays",
x = "Date",
y = "Average Delay (Minutes)",
color = "Metric"
) +
theme(legend.position = "bottom")
print(p1)
# Save it for your report
ggsave("viz_time_series.png", plot = p1, width = 10, height = 6)
# ==========================================
# VISUALIZATION 2: CARRIER PERFORMANCE
# Goal: Compare which airlines are the worst.
# ==========================================
p2 <- ggplot(carrier_df, aes(x = reorder(CarrierName, AvgArrDelay), y = AvgArrDelay)) +
geom_bar(stat = "identity", fill = "#2C3E50") +
coord_flip() + # Flip to make names readable
theme_minimal() +
labs(
title = "Airline Performance Ranking",
subtitle = "Average Arrival Delay by Carrier",
x = "Airline",
y = "Avg Arrival Delay (Minutes)"
) +
geom_text(aes(label = round(AvgArrDelay, 1)), hjust = -0.2, size = 3)
print(p2)
ggsave("viz_carrier_ranking.png", plot = p2, width = 10, height = 8)
# ==========================================
# VISUALIZATION 3: CANCELLATION RATE VS VOLUME
# Goal: Bubble chart showing reliability vs size.
# ==========================================
p3 <- ggplot(carrier_df, aes(x = TotalFlights, y = CancelRate, label = CarrierName)) +
geom_point(aes(size = AvgArrDelay), color = "#D35400", alpha = 0.7) +
geom_text(vjust = 1.5, size = 3, check_overlap = TRUE) +
scale_x_log10(labels = label_number(scale_cut = cut_short_scale())) + # Log scale for huge differences
theme_light() +
labs(
title = "Reliability Matrix: Volume vs. Cancellations",
subtitle = "Size of bubble = Average Delay Severity",
x = "Total Flights (Log Scale)",
y = "Cancellation Rate (%)",
size = "Avg Delay"
)
print(p3)
ggsave("viz_reliability_matrix.png", plot = p3, width = 10, height = 6)
message("Analysis Complete. 3 plots saved to working directory.")
